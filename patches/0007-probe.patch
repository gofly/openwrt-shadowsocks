@@ -0,0 +1,280 @@
+/*
+ * probe.c - Active probing for remote server status
+ *
+ * Copyright (C) 2019, zkc <zkc@tcpip.fun>
+ *
+ * This file is part of the shadowsocks-libev.
+ *
+ * shadowsocks-libev is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License as published by
+ * the Free Software Foundation; either version 3 of the License, or
+ * (at your option) any later version.
+ *
+ * shadowsocks-libev is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the
+ * GNU General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public License
+ * along with shadowsocks-libev; see the file COPYING. If not, see
+ * <http://www.gnu.org/licenses/>.
+ */
+
+#include <string.h>
+#include <errno.h>
+#include <unistd.h>
+#include <netinet/in.h>
+#include <arpa/inet.h>
+
+#include <libcork/core.h>
+
+#include "probe.h"
+#include "utils.h"
+#include "netutils.h"
+
+#define MAX_LISTENERS 32
+
+/* TCP Probe */
+typedef struct tcp_probe_ctx {
+    ev_io io;
+    ev_timer watcher;
+    int remote_idx;
+    listen_ctx_t *listener;
+} tcp_probe_ctx_t;
+
+static ev_timer tcp_probe_timer;
+static listen_ctx_t *tcp_listeners[MAX_LISTENERS] = { NULL };
+static int tcp_listener_count = 0;
+
+/* UDP Probe */
+typedef struct udp_probe_ctx {
+    ev_io io;
+    ev_timer watcher;
+    int remote_idx;
+    server_ctx_t *server_ctx;
+    crypto_t *crypto;
+} udp_probe_ctx_t;
+
+static ev_timer udp_probe_timer;
+static server_ctx_t *udp_servers[MAX_LISTENERS] = { NULL };
+static int udp_server_count = 0;
+
+static const unsigned char dns_probe_packet[] = {
+    0xDB, 0x42, 0x01, 0x00, 0x00, 0x01, 0x00, 0x00,
+    0x00, 0x00, 0x00, 0x00, 0x03, 0x77, 0x77, 0x77,
+    0x06, 0x67, 0x6f, 0x6f, 0x67, 0x6c, 0x65, 0x03,
+    0x63, 0x6f, 0x6d, 0x00, 0x00, 0x01, 0x00, 0x01
+};
+
+/* TCP Probe Implementation */
+static void tcp_probe_cleanup(EV_P_ tcp_probe_ctx_t *p_ctx) {
+    ev_io_stop(EV_A_ &p_ctx->io);
+    ev_timer_stop(EV_A_ &p_ctx->watcher);
+    close(p_ctx->io.fd);
+    ss_free(p_ctx);
+}
+
+static void tcp_probe_connect_cb(EV_P_ ev_io *w, int revents) {
+    tcp_probe_ctx_t *p_ctx = (tcp_probe_ctx_t *)w;
+    int err;
+    socklen_t len = sizeof(err);
+
+    if (getsockopt(w->fd, SOL_SOCKET, SO_ERROR, &err, &len) == -1) {
+        err = errno;
+    }
+
+    if (err == 0) {
+        if (!p_ctx->listener->remote_status[p_ctx->remote_idx]) {
+            LOGI("[tcp-probe] remote %d is back online.", p_ctx->remote_idx);
+        }
+        p_ctx->listener->remote_status[p_ctx->remote_idx] = true;
+    } else {
+        if (p_ctx->listener->remote_status[p_ctx->remote_idx]) {
+            LOGI("[tcp-probe] remote %d is offline: %s", p_ctx->remote_idx, strerror(err));
+        }
+        p_ctx->listener->remote_status[p_ctx->remote_idx] = false;
+    }
+    tcp_probe_cleanup(EV_A_ p_ctx);
+}
+
+static void tcp_probe_timeout_cb(EV_P_ ev_timer *w, int revents) {
+    tcp_probe_ctx_t *p_ctx = cork_container_of(w, tcp_probe_ctx_t, watcher);
+    if (p_ctx->listener->remote_status[p_ctx->remote_idx]) {
+        LOGI("[tcp-probe] remote %d timed out.", p_ctx->remote_idx);
+    }
+    p_ctx->listener->remote_status[p_ctx->remote_idx] = false;
+    tcp_probe_cleanup(EV_A_ p_ctx);
+}
+
+static void start_one_tcp_probe(EV_P_ listen_ctx_t *listener, int idx) {
+    struct sockaddr *remote_addr = listener->remote_addr[idx];
+    int probefd = socket(remote_addr->sa_family, SOCK_STREAM, 0);
+    if (probefd == -1) {
+        listener->remote_status[idx] = false;
+        return;
+    }
+
+    setnonblocking(probefd);
+
+    tcp_probe_ctx_t *p_ctx = ss_malloc(sizeof(tcp_probe_ctx_t));
+    memset(p_ctx, 0, sizeof(tcp_probe_ctx_t));
+    p_ctx->listener = listener;
+    p_ctx->remote_idx = idx;
+
+    ev_io_init(&p_ctx->io, tcp_probe_connect_cb, probefd, EV_WRITE);
+    ev_timer_init(&p_ctx->watcher, tcp_probe_timeout_cb, min(MAX_CONNECT_TIMEOUT, 5), 0);
+
+    if (connect(probefd, remote_addr, get_sockaddr_len(remote_addr)) != 0 && errno != EINPROGRESS) {
+        listener->remote_status[idx] = false;
+        close(probefd);
+        ss_free(p_ctx);
+        return;
+    }
+
+    ev_io_start(EV_A_ &p_ctx->io);
+    ev_timer_start(EV_A_ &p_ctx->watcher);
+}
+
+static void tcp_probe_timer_cb(EV_P_ ev_timer *w, int revents) {
+    for (int i = 0; i < tcp_listener_count; i++) {
+        listen_ctx_t *lc = tcp_listeners[i];
+        if (lc && lc->remote_num > 1) {
+            for (int j = 0; j < lc->remote_num; j++) {
+                start_one_tcp_probe(EV_A_ lc, j);
+            }
+        }
+    }
+}
+
+/* UDP Probe Implementation */
+static void udp_probe_cleanup(EV_P_ udp_probe_ctx_t *p_ctx) {
+    ev_io_stop(EV_A_ &p_ctx->io);
+    ev_timer_stop(EV_A_ &p_ctx->watcher);
+    close(p_ctx->io.fd);
+    ss_free(p_ctx);
+}
+
+static void udp_probe_recv_cb(EV_P_ ev_io *w, int revents) {
+    udp_probe_ctx_t *p_ctx = (udp_probe_ctx_t *)w;
+    buffer_t *buf = ss_malloc(sizeof(buffer_t));
+    balloc(buf, MAX_UDP_PACKET_SIZE);
+
+    ssize_t r = recv(p_ctx->io.fd, buf->data, MAX_UDP_PACKET_SIZE, 0);
+    bool success = false;
+    if (r > 0) {
+        buf->len = r;
+        if (p_ctx->crypto->decrypt_all(buf, p_ctx->crypto->cipher, buf->capacity) == 0) {
+            if (buf->len > 3 && (buf->data[3] & 0x0F) == 0) {
+                success = true;
+            }
+        }
+    }
+
+    if (success) {
+        if (!p_ctx->server_ctx->remote_status[p_ctx->remote_idx]) {
+            LOGI("[udp-probe] remote %d is back online.", p_ctx->remote_idx);
+        }
+        p_ctx->server_ctx->remote_status[p_ctx->remote_idx] = true;
+    } else {
+        if (p_ctx->server_ctx->remote_status[p_ctx->remote_idx]) {
+            LOGI("[udp-probe] remote %d failed probe.", p_ctx->remote_idx);
+        }
+        p_ctx->server_ctx->remote_status[p_ctx->remote_idx] = false;
+    }
+
+    bfree(buf);
+    ss_free(buf);
+    udp_probe_cleanup(EV_A_ p_ctx);
+}
+
+static void udp_probe_timeout_cb(EV_P_ ev_timer *w, int revents) {
+    udp_probe_ctx_t *p_ctx = cork_container_of(w, udp_probe_ctx_t, watcher);
+    if (p_ctx->server_ctx->remote_status[p_ctx->remote_idx]) {
+        LOGI("[udp-probe] remote %d timed out.", p_ctx->remote_idx);
+    }
+    p_ctx->server_ctx->remote_status[p_ctx->remote_idx] = false;
+    udp_probe_cleanup(EV_A_ p_ctx);
+}
+
+static void start_one_udp_probe(EV_P_ server_ctx_t *s_ctx, int idx) {
+    struct sockaddr *remote_addr = s_ctx->remote_addr[idx];
+    int probefd = socket(remote_addr->sa_family, SOCK_DGRAM, 0);
+    if (probefd == -1) return;
+
+    setnonblocking(probefd);
+
+    buffer_t *buf = ss_malloc(sizeof(buffer_t));
+    balloc(buf, sizeof(dns_probe_packet) + MAX_ADDR_HEADER_SIZE);
+    memcpy(buf->data, dns_probe_packet, sizeof(dns_probe_packet));
+    buf->len = sizeof(dns_probe_packet);
+
+    if (s_ctx->crypto->encrypt_all(buf, s_ctx->crypto->cipher, buf->capacity) != 0) {
+        bfree(buf);
+        ss_free(buf);
+        close(probefd);
+        return;
+    }
+
+    sendto(probefd, buf->data, buf->len, 0, remote_addr, get_sockaddr_len(remote_addr));
+    bfree(buf);
+    ss_free(buf);
+
+    udp_probe_ctx_t *p_ctx = ss_malloc(sizeof(udp_probe_ctx_t));
+    memset(p_ctx, 0, sizeof(udp_probe_ctx_t));
+    p_ctx->server_ctx = s_ctx;
+    p_ctx->remote_idx = idx;
+    p_ctx->crypto = s_ctx->crypto;
+
+    ev_io_init(&p_ctx->io, udp_probe_recv_cb, probefd, EV_READ);
+    ev_timer_init(&p_ctx->watcher, udp_probe_timeout_cb, 5.0, 0);
+    ev_io_start(EV_A_ &p_ctx->io);
+    ev_timer_start(EV_A_ &p_ctx->watcher);
+}
+
+static void udp_probe_timer_cb(EV_P_ ev_timer *w, int revents) {
+    for (int i = 0; i < udp_server_count; i++) {
+        server_ctx_t *s_ctx = udp_servers[i];
+        if (s_ctx && s_ctx->remote_num > 1) {
+            for (int j = 0; j < s_ctx->remote_num; j++) {
+                start_one_udp_probe(EV_A_ s_ctx, j);
+            }
+        }
+    }
+}
+
+/* Public Interface */
+void probe_init(EV_P_ int tcp_interval, int udp_interval) {
+    ev_timer_init(&tcp_probe_timer, tcp_probe_timer_cb, tcp_interval, tcp_interval);
+    ev_timer_init(&udp_probe_timer, udp_probe_timer_cb, udp_interval, udp_interval);
+}
+
+void probe_add_tcp_listener(listen_ctx_t *listener) {
+    if (tcp_listener_count < MAX_LISTENERS) {
+        tcp_listeners[tcp_listener_count++] = listener;
+        if (listener->remote_num > 1 && !ev_is_active(&tcp_probe_timer)) {
+            ev_timer_start(EV_DEFAULT, &tcp_probe_timer);
+        }
+    } else {
+        LOGE("[probe] too many tcp listeners");
+    }
+}
+
+void probe_add_udp_server(server_ctx_t *server) {
+    if (udp_server_count < MAX_LISTENERS) {
+        udp_servers[udp_server_count++] = server;
+        if (server->remote_num > 1 && !ev_is_active(&udp_probe_timer)) {
+            ev_timer_start(EV_DEFAULT, &udp_probe_timer);
+        }
+    } else {
+        LOGE("[probe] too many udp servers");
+    }
+}
+
+void probe_cleanup(EV_P) {
+    if (ev_is_active(&tcp_probe_timer)) {
+        ev_timer_stop(EV_A_ &tcp_probe_timer);
+    }
+    if (ev_is_active(&udp_probe_timer)) {
+        ev_timer_stop(EV_A_ &udp_probe_timer);
+    }
+}
