+                    ((struct sockaddr_storage*)storage)->ss_family = AF_UNSPEC;
                 }
+            } else {
+                /* try resolving later — for now leave storage untouched or AF_UNSPEC */
+                ((struct sockaddr_storage*)storage)->ss_family = AF_UNSPEC;
             }
-            if (host != NULL) {
-                memcpy(host, buf + offset + 1, name_len);
-            }
-            offset += 1 + name_len;
