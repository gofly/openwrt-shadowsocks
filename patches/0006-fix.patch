diff --git a/src/redir.c b/src/redir.c
index 8617b76..9f870a0 100644
--- a/src/redir.c
+++ b/src/redir.c
@@ -771,6 +771,14 @@ failover_to_next_remote(EV_P_ server_t *server)
         server->remote = NULL;
     }
 
+    /*
+     * Reset cipher context before trying the next remote.
+     * Each new connection attempt to a remote must start with a fresh cipher context,
+     * especially for AEAD ciphers, to send a new salt/IV.
+     */
+    crypto->ctx_init(crypto->cipher, server->e_ctx, 1);
+    crypto->ctx_init(crypto->cipher, server->d_ctx, 0);
+
     /* advance to next remote index for this server + listener */
     if (server->listener && server->listener->remote_num > 0) {
         server->remote_idx = (server->remote_idx + 1) % server->listener->remote_num;
