+    /* 如果这个 remote_ctx 正代表当前 listener 的 preferred remote，则做 failover（移动 preferred_remote_idx） */
+    if (server_ctx->remote_num > 1 && remote_ctx->remote_idx == server_ctx->preferred_remote_idx) {
+        server_ctx->preferred_remote_idx = (server_ctx->preferred_remote_idx + 1) % server_ctx->remote_num;
