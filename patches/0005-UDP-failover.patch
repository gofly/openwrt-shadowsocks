+
+/* failback: reset all server_ctx preferred idx to 0 periodically */
+static void
+failback_cb(EV_P_ ev_timer *w, int revents)
+{
+    (void)w; (void)revents;
+    for (int i = 0; i < server_num; i++) {
+        server_ctx_t *s_ctx = server_ctx_list[i];
+        if (s_ctx && s_ctx->preferred_remote_idx > 0) {
+            LOGI("[udp] failback: resetting preferred_remote_idx for server_ctx %p (%d -> 0)",
+                 (void*)s_ctx, s_ctx->preferred_remote_idx);
+            s_ctx->preferred_remote_idx = 0;
+        }
+    }
+}
