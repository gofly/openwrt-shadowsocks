+    server_ctx_t *server_ctx = remote_ctx->server_ctx;
+
+    ev_timer_stop(EV_A_ & remote_ctx->watcher);
+
+    if (server_ctx == NULL) {
+        close_and_free_remote(EV_A_ remote_ctx);
